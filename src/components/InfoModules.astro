---
import { getTranslationsFor } from '@i18n/index'
import AppFooter from './AppFooter.astro'
import type { Locale } from '@store/locale'

interface Props {
	locale: Locale
}

const { locale } = Astro.props
const t = getTranslationsFor(locale)
const BASE = ''
---

<nav class='mb-6'>
	<a
		href={`${BASE}/${locale}/`}
		class='brutalist-border bg-obsidian inline-block py-2 text-[clamp(13px,1.5vw,15px)] font-bold text-gray-400 transition-all hover:border-gray-100 hover:text-gray-700'
	>
		{t.back_to_calculator}
	</a>
</nav>

<div class='flex flex-col gap-8'>
	<!-- Module 01: LBM -->
	<section class='brutalist-border bg-obsidian p-2'>
		<p class='mb-4 text-[clamp(13px,1.5vw,15px)] opacity-75'>◉ {t.info_module_01}</p>
		<h2 class='mb-4 border-b-2 border-[#4A4A4A] pb-2 text-xl font-extrabold italic'>{t.info_lbm_title}</h2>

		<div class='mb-4 space-y-2 text-[clamp(13px,1.5vw,15px)]'>
			<p class='text-gray-600'>{t.info_lbm_desc}</p>
		</div>

		<div class='space-y-4'>
			<div class='border-l-4 border-[#4A4A4A] pl-4'>
				<p class='mb-1 text-[clamp(13px,1.5vw,15px)] font-bold'>{t.info_lbm_boer_label}</p>
				<p class='text-concrete text-[clamp(12px,1.3vw,14px)]'>{t.male}: 0.407 × W + 0.267 × H − 19.2</p>
				<p class='text-concrete text-[clamp(12px,1.3vw,14px)]'>{t.female}: 0.252 × W + 0.473 × H − 48.3</p>
				<p class='mt-1 text-[clamp(12px,1.3vw,14px)] opacity-70'>{t.info_lbm_boer_note}</p>
			</div>

			<div class='border-l-4 border-gray-200 pl-4'>
				<p class='mb-1 text-[clamp(13px,1.5vw,15px)] font-bold'>JAMES</p>
				<p class='text-concrete text-[clamp(12px,1.3vw,14px)]'>{t.male}: 1.1 × W − 128 × (W/H)²</p>
				<p class='text-concrete text-[clamp(12px,1.3vw,14px)]'>{t.female}: 1.07 × W − 148 × (W/H)²</p>
				<p class='mt-1 text-[clamp(12px,1.3vw,14px)] opacity-70'>{t.info_lbm_james_note}</p>
			</div>

			<div class='border-l-4 border-gray-200 pl-4'>
				<p class='mb-1 text-[clamp(13px,1.5vw,15px)] font-bold'>HUME</p>
				<p class='text-concrete text-[clamp(12px,1.3vw,14px)]'>{t.male}: 0.3281 × W + 0.33929 × H − 29.5336</p>
				<p class='text-concrete text-[clamp(12px,1.3vw,14px)]'>{t.female}: 0.29569 × W + 0.41813 × H − 43.2933</p>
			</div>

			<div class='border-l-4 border-gray-200 pl-4'>
				<p class='mb-1 text-[clamp(13px,1.5vw,15px)] font-bold'>{t.lbm_manual.toUpperCase()}</p>
				<p class='text-concrete text-[clamp(12px,1.3vw,14px)]'>{t.info_lbm_manual_desc}</p>
			</div>
		</div>
	</section>

	<!-- Module 02: BMR -->
	<section class='brutalist-border bg-obsidian p-2'>
		<p class='mb-4 text-[clamp(13px,1.5vw,15px)] opacity-75'>◉ {t.info_module_02}</p>
		<h2 class='mb-4 border-b-2 border-[#4A4A4A] pb-2 text-xl font-extrabold italic'>{t.info_bmr_title}</h2>

		<div class='mb-4 space-y-2 text-[clamp(13px,1.5vw,15px)]'>
			<p class='text-gray-600'>{t.info_bmr_desc}</p>
		</div>

		<div class='space-y-4'>
			<div class='border-l-4 border-gray-200 pl-4'>
				<p class='mb-1 text-[clamp(13px,1.5vw,15px)] font-bold'>MIFFLIN-ST JEOR</p>
				<p class='text-concrete text-[clamp(12px,1.3vw,14px)]'>{t.male}: 10W + 6.25H − 5A + 5</p>
				<p class='text-concrete text-[clamp(12px,1.3vw,14px)]'>{t.female}: 10W + 6.25H − 5A − 161</p>
				<p class='mt-1 text-[clamp(12px,1.3vw,14px)] opacity-70'>{t.info_bmr_mifflin_note}</p>
			</div>

			<div class='border-l-4 border-gray-200 pl-4'>
				<p class='mb-1 text-[clamp(13px,1.5vw,15px)] font-bold'>REVISED HARRIS-BENEDICT</p>
				<p class='text-concrete text-[clamp(12px,1.3vw,14px)]'>{t.male}: 13.397W + 4.799H − 5.677A + 88.362</p>
				<p class='text-concrete text-[clamp(12px,1.3vw,14px)]'>{t.female}: 9.247W + 3.098H − 4.33A + 447.593</p>
				<p class='mt-1 text-[clamp(12px,1.3vw,14px)] opacity-70'>{t.info_bmr_harris_note}</p>
			</div>

			<div class='border-l-4 border-[#4A4A4A] pl-4'>
				<p class='mb-1 text-[clamp(13px,1.5vw,15px)] font-bold'>{t.info_bmr_katch_label}</p>
				<p class='text-concrete text-[clamp(12px,1.3vw,14px)]'>370 + 21.6 × LBM (kg)</p>
				<p class='mt-1 text-[clamp(12px,1.3vw,14px)] opacity-70'>{t.info_bmr_katch_note}</p>
			</div>
		</div>
	</section>

	<!-- Module 03: TDEE -->
	<section class='brutalist-border bg-obsidian p-2'>
		<p class='mb-4 text-[clamp(13px,1.5vw,15px)] opacity-75'>◉ {t.info_module_03}</p>
		<h2 class='mb-4 border-b-2 border-[#4A4A4A] pb-2 text-xl font-extrabold italic'>{t.info_tdee_title}</h2>

		<div class='mb-4 text-[clamp(13px,1.5vw,15px)]'>
			<p class='text-gray-600'>{t.info_tdee_desc}</p>
			<p class='text-concrete mt-2 text-[clamp(12px,1.3vw,14px)] font-bold'>{t.info_tdee_formula}</p>
		</div>

		<div class='space-y-2'>
			<div class='flex justify-between border-b border-[#4A4A4A] py-2 text-[clamp(12px,1.3vw,14px)]'>
				<span class='font-bold'>{t.exercise_sedentary.toUpperCase()}</span>
				<span class='text-concrete'>{t.info_tdee_sedentary_desc}</span>
			</div>
			<div class='flex justify-between border-b border-[#4A4A4A] py-2 text-[clamp(12px,1.3vw,14px)]'>
				<span class='font-bold'>{t.exercise_lightly.toUpperCase()}</span>
				<span class='text-concrete'>{t.info_tdee_lightly_desc}</span>
			</div>
			<div class='flex justify-between border-b border-[#4A4A4A] py-2 text-[clamp(12px,1.3vw,14px)]'>
				<span class='font-bold'>{t.exercise_moderately.toUpperCase()}</span>
				<span class='text-concrete'>{t.info_tdee_moderately_desc}</span>
			</div>
			<div class='flex justify-between border-b border-[#4A4A4A] py-2 text-[clamp(12px,1.3vw,14px)]'>
				<span class='font-bold'>{t.exercise_very.toUpperCase()}</span>
				<span class='text-concrete'>{t.info_tdee_very_desc}</span>
			</div>
			<div class='flex justify-between py-2 text-[clamp(12px,1.3vw,14px)]'>
				<span class='font-bold'>{t.exercise_extremely.toUpperCase()}</span>
				<span class='text-concrete'>{t.info_tdee_extremely_desc}</span>
			</div>
		</div>
	</section>

	<!-- Module 04: Goals -->
	<section class='brutalist-border bg-obsidian p-2'>
		<p class='mb-4 text-[clamp(13px,1.5vw,15px)] opacity-75'>◉ {t.info_module_04}</p>
		<h2 class='mb-4 border-b-2 border-[#4A4A4A] pb-2 text-xl font-extrabold italic'>{t.info_goals_title}</h2>

		<div class='space-y-4'>
			<div class='border-l-4 border-[#4A4A4A] pl-4'>
				<p class='mb-1 text-[clamp(13px,1.5vw,15px)] font-bold'>{t.goal_maintain.toUpperCase()}</p>
				<p class='text-concrete text-[clamp(12px,1.3vw,14px)]'>{t.info_goal_maintain_formula}</p>
				<p class='mt-1 text-[clamp(12px,1.3vw,14px)] opacity-70'>{t.info_goal_maintain_desc}</p>
			</div>
			<div class='border-l-4 border-gray-200 pl-4'>
				<p class='mb-1 text-[clamp(13px,1.5vw,15px)] font-bold'>{t.goal_surplus.toUpperCase()}</p>
				<p class='text-concrete text-[clamp(12px,1.3vw,14px)]'>{t.info_goal_surplus_formula}</p>
				<p class='mt-1 text-[clamp(12px,1.3vw,14px)] opacity-70'>{t.info_goal_surplus_desc}</p>
			</div>
			<div class='border-l-4 border-gray-200 pl-4'>
				<p class='mb-1 text-[clamp(13px,1.5vw,15px)] font-bold'>{t.goal_definition.toUpperCase()}</p>
				<p class='text-concrete text-[clamp(12px,1.3vw,14px)]'>{t.info_goal_definition_formula}</p>
				<p class='mt-1 text-[clamp(12px,1.3vw,14px)] opacity-70'>{t.info_goal_definition_desc}</p>
			</div>
		</div>
	</section>

	<!-- Module 05: Macronutrients -->
	<section class='brutalist-border bg-obsidian p-2'>
		<p class='mb-4 text-[clamp(13px,1.5vw,15px)] opacity-75'>◉ {t.info_module_05}</p>
		<h2 class='mb-4 border-b-2 border-[#4A4A4A] pb-2 text-xl font-extrabold italic'>{t.info_macros_title}</h2>

		<div class='mb-4 text-[clamp(13px,1.5vw,15px)]'>
			<p class='text-gray-600'>{t.info_macros_desc}</p>
		</div>

		<div class='mb-6 space-y-2'>
			<div class='flex justify-between border-b border-[#4A4A4A] py-2 text-[clamp(12px,1.3vw,14px)]'>
				<span class='font-bold'>{t.info_macro_protein}</span>
				<span class='text-concrete'>4 kcal / gram</span>
			</div>
			<div class='flex justify-between border-b border-[#4A4A4A] py-2 text-[clamp(12px,1.3vw,14px)]'>
				<span class='font-bold'>{t.info_macro_carbohydrates}</span>
				<span class='text-concrete'>4 kcal / gram</span>
			</div>
			<div class='flex justify-between py-2 text-[clamp(12px,1.3vw,14px)]'>
				<span class='font-bold'>{t.info_macro_fat}</span>
				<span class='text-concrete'>9 kcal / gram</span>
			</div>
		</div>

		<div class='space-y-3 border-t-2 border-dashed border-[#4A4A4A] pt-4'>
			<p class='text-[clamp(13px,1.5vw,15px)] font-bold'>{t.info_protein_targets}</p>
			<div class='flex justify-between text-[clamp(12px,1.3vw,14px)]'>
				<span class='text-concrete'>{t.goal_maintain}</span>
				<span>1.8 g/kg</span>
			</div>
			<div class='flex justify-between text-[clamp(12px,1.3vw,14px)]'>
				<span class='text-concrete'>{t.goal_surplus}</span>
				<span>2.0 g/kg</span>
			</div>
			<div class='flex justify-between text-[clamp(12px,1.3vw,14px)]'>
				<span class='text-concrete'>{t.goal_definition}</span>
				<span>2.5 g/kg</span>
			</div>
		</div>

		<div class='mt-4 space-y-3 border-t-2 border-dashed border-[#4A4A4A] pt-4'>
			<p class='text-[clamp(13px,1.5vw,15px)] font-bold'>{t.info_fat_targets}</p>
			<div class='flex justify-between text-[clamp(12px,1.3vw,14px)]'>
				<span class='text-concrete'>{t.goal_maintain}</span>
				<span>1.0 g/kg LBM</span>
			</div>
			<div class='flex justify-between text-[clamp(12px,1.3vw,14px)]'>
				<span class='text-concrete'>{t.goal_surplus}</span>
				<span>25% of total kcal</span>
			</div>
			<div class='flex justify-between text-[clamp(12px,1.3vw,14px)]'>
				<span class='text-concrete'>{t.goal_definition}</span>
				<span>0.9 g/kg LBM</span>
			</div>
		</div>

		<div class='mt-4 border-t-2 border-dashed border-[#4A4A4A] pt-4'>
			<p class='text-[clamp(13px,1.5vw,15px)] font-bold'>{t.info_carbs_label}</p>
			<p class='text-concrete mt-1 text-[clamp(12px,1.3vw,14px)]'>{t.info_carbs_formula}</p>
		</div>
	</section>

	<!-- FAQ — visible content, also feeds JSON-LD FAQPage -->
	<section class='brutalist-border bg-obsidian p-2'>
		<p class='mb-4 text-[clamp(13px,1.5vw,15px)] opacity-75'>◉ FAQ</p>
		<h2 class='mb-6 border-b-2 border-[#4A4A4A] pb-2 text-xl font-extrabold italic'>{t.info_faq_title}</h2>
		<div class='space-y-4'>
			{
				[
					{ q: t.seo_faq_lbm_q, a: t.seo_faq_lbm_a },
					{ q: t.seo_faq_bmr_q, a: t.seo_faq_bmr_a },
					{ q: t.seo_faq_tdee_q, a: t.seo_faq_tdee_a },
					{ q: t.seo_faq_macros_q, a: t.seo_faq_macros_a },
					{ q: t.seo_faq_goals_q, a: t.seo_faq_goals_a },
				].map(({ q, a }) => (
					<details class='border-l-4 border-gray-200 pl-4'>
						<summary class='cursor-pointer text-[clamp(13px,1.5vw,15px)] font-bold text-gray-700 hover:text-gray-900'>{q}</summary>
						<p class='text-concrete mt-2 text-[clamp(12px,1.3vw,14px)] leading-relaxed'>{a}</p>
					</details>
				))
			}
		</div>
	</section>
</div>

<AppFooter locale={locale} page='info' />
