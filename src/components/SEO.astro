---
import { getTranslationsFor } from '@i18n/index'
import type { Locale } from '@store/locale'

interface Props {
	locale: Locale
	page: 'home' | 'info'
}

const { locale, page } = Astro.props
const t = getTranslationsFor(locale)

const LOCALES: Locale[] = ['en', 'es', 'fr', 'zh', 'hi']
const BASE = ''
const SITE = 'https://macrocalc.fit'

const BCP47: Record<Locale, string> = {
	en: 'en_US',
	es: 'es_ES',
	fr: 'fr_FR',
	zh: 'zh_CN',
	hi: 'hi_IN',
}

const pageSlug = page === 'home' ? '' : '/info'
const canonicalUrl = `${SITE}${BASE}/${locale}${pageSlug}`
const ogImage = `${SITE}${BASE}/og-image.png`

const title = page === 'home' ? t.seo_home_title : t.seo_info_title
const description = page === 'home' ? t.seo_home_description : t.seo_info_description

const faqItems = [
	{ q: t.seo_faq_lbm_q, a: t.seo_faq_lbm_a },
	{ q: t.seo_faq_bmr_q, a: t.seo_faq_bmr_a },
	{ q: t.seo_faq_tdee_q, a: t.seo_faq_tdee_a },
	{ q: t.seo_faq_macros_q, a: t.seo_faq_macros_a },
	{ q: t.seo_faq_goals_q, a: t.seo_faq_goals_a },
]

const webAppSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebApplication',
	name: 'MacroCalc',
	url: `${SITE}${BASE}/${locale}/`,
	description: t.seo_home_description,
	applicationCategory: 'HealthApplication',
	operatingSystem: 'Any',
	inLanguage: locale,
	offers: {
		'@type': 'Offer',
		price: '0',
		priceCurrency: 'USD',
	},
	author: {
		'@type': 'Person',
		name: 'Alberto García Sola',
	},
	softwareVersion: '1.0',
}

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'MacroCalc',
			item: `${SITE}${BASE}/${locale}/`,
		},
		...(page === 'info'
			? [
					{
						'@type': 'ListItem',
						position: 2,
						name: t.seo_info_title,
						item: canonicalUrl,
					},
				]
			: []),
	],
}

const faqSchema =
	page === 'info'
		? {
				'@context': 'https://schema.org',
				'@type': 'FAQPage',
				mainEntity: faqItems.map(({ q, a }) => ({
					'@type': 'Question',
					name: q,
					acceptedAnswer: {
						'@type': 'Answer',
						text: a,
					},
				})),
			}
		: null
---

<!-- Primary -->
<title>{title}</title>
<meta name='description' content={description} />
{page === 'home' && <meta name='keywords' content={t.seo_home_keywords} />}
<meta name='author' content='Alberto García Sola' />
<meta name='robots' content='index, follow, max-image-preview:large' />
<meta name='theme-color' content='#0A0A0A' />

<!-- Canonical + hreflang -->
<link rel='canonical' href={canonicalUrl} />
{LOCALES.map((loc) => <link rel='alternate' hreflang={loc} href={`${SITE}${BASE}/${loc}${pageSlug}`} />)}
<link rel='alternate' hreflang='x-default' href={`${SITE}${BASE}/en${pageSlug}`} />

<!-- Open Graph -->
<meta property='og:type' content='website' />
<meta property='og:site_name' content='MacroCalc' />
<meta property='og:title' content={title} />
<meta property='og:description' content={description} />
<meta property='og:url' content={canonicalUrl} />
<meta property='og:locale' content={BCP47[locale]} />
{LOCALES.filter((l) => l !== locale).map((l) => <meta property='og:locale:alternate' content={BCP47[l]} />)}
<meta property='og:image' content={ogImage} />
<meta property='og:image:width' content='1200' />
<meta property='og:image:height' content='630' />
<meta property='og:image:alt' content={t.seo_og_tagline} />

<!-- Twitter / X -->
<meta name='twitter:card' content='summary_large_image' />
<meta name='twitter:title' content={title} />
<meta name='twitter:description' content={description} />
<meta name='twitter:image' content={ogImage} />
<meta name='twitter:image:alt' content={t.seo_og_tagline} />

<!-- PWA / icons -->
<link rel='manifest' href={`${BASE}/manifest.webmanifest`} />
<link rel='apple-touch-icon' href={`${BASE}/apple-touch-icon.png`} />

<!-- JSON-LD -->
<script is:inline type='application/ld+json' set:html={JSON.stringify(webAppSchema)} />
<script is:inline type='application/ld+json' set:html={JSON.stringify(breadcrumbSchema)} />
{faqSchema && <script is:inline type='application/ld+json' set:html={JSON.stringify(faqSchema)} />}
