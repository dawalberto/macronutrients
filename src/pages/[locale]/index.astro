---
import { AdditionalSettings } from '@components/AdditionalSettings'
import { AppHeader } from '@components/AppHeader'
import ChartMacros from '@components/ChartMacros.astro'
import { Dashboard } from '@components/Dashboard'
import { ExerciseMultiplier } from '@components/ExerciseMultiplier'
import { InterpretResults } from '@components/InterpretResults'
import { GoalSelector } from '@components/GoalSelector'
import { LanguageSelector } from '@components/LanguageSelector'
import SEO from '@components/SEO.astro'
import { getTranslationsFor } from '@i18n/index'
import '@styles/global.css'

export function getStaticPaths() {
	return [
		{ params: { locale: 'en' } },
		{ params: { locale: 'es' } },
		{ params: { locale: 'fr' } },
		{ params: { locale: 'zh' } },
		{ params: { locale: 'hi' } },
	]
}

const { locale } = Astro.params as { locale: 'en' | 'es' | 'fr' | 'zh' | 'hi' }
const t = getTranslationsFor(locale)

const BASE = '/macronutrients'
---

<html lang={locale}>
	<head>
		<meta charset='utf-8' />
		<link rel='icon' type='image/svg+xml' href={`${BASE}/favicon.svg`} />
		<meta name='viewport' content='width=device-width' />
		<meta name='generator' content={Astro.generator} />
		<link rel='preconnect' href='https://fonts.googleapis.com' />
		<link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
		<link href='https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,700;0,800;1,800&display=swap' rel='stylesheet' />

		<SEO locale={locale} page='home' />
	</head>
	<body class='min-h-screen bg-[#0A0A0A] text-gray-100'>
		<div class='mx-auto w-full max-w-xl p-4 md:p-8'>
			<AppHeader client:only='react' />

			<div class='flex flex-col gap-8'>
				<Dashboard client:only='react' />
				<ExerciseMultiplier client:only='react' />
				<GoalSelector client:only='react' />
				<ChartMacros />
				<InterpretResults client:only='react' />
				<AdditionalSettings client:only='react' />
			</div>

			<!-- Static SEO content: H1 + description visible to crawlers -->
			<section class='mt-8 border-t-2 border-dashed border-[#4A4A4A] pt-8'>
				<h1 class='sr-only'>{t.seo_home_title}</h1>
				<p class='mb-6 text-[clamp(10px,1vw,11px)] text-concrete opacity-60'>{t.seo_home_description}</p>

				<!-- FAQ: visible + feeds JSON-LD -->
				<div class='space-y-2'>
					{[
						{ q: t.seo_faq_lbm_q, a: t.seo_faq_lbm_a },
						{ q: t.seo_faq_bmr_q, a: t.seo_faq_bmr_a },
						{ q: t.seo_faq_tdee_q, a: t.seo_faq_tdee_a },
						{ q: t.seo_faq_macros_q, a: t.seo_faq_macros_a },
						{ q: t.seo_faq_goals_q, a: t.seo_faq_goals_a },
					].map(({ q, a }) => (
						<details class='border-l-2 border-[#4A4A4A] pl-3'>
							<summary class='cursor-pointer text-[clamp(9px,0.9vw,10px)] font-bold text-gray-500 hover:text-gray-300'>
								{q}
							</summary>
							<p class='mt-1 text-[clamp(8px,0.85vw,9px)] text-concrete opacity-50 leading-relaxed'>{a}</p>
						</details>
					))}
				</div>
			</section>

			<footer class='mt-8 border-t-2 border-dashed border-[#4A4A4A] py-12'>
				<nav class='mb-6 flex justify-center'>
					<a
						href={`${BASE}/${locale}/info`}
						class='text-[clamp(10px,1.1vw,12px)] font-bold opacity-40 transition-opacity hover:opacity-100'
					>
						{t.footer_info_link}
					</a>
				</nav>
				<div class='mb-6 flex justify-center'>
					<LanguageSelector client:only='react' />
				</div>
				<div class='space-y-2 text-center text-[clamp(8px,1vw,10px)] opacity-40'>
					<p>DATA_RECONSTRUCTED // UNIT_SYSTEM: METRIC // SOURCE: MIFFLIN-ST_JEOR_REVISED</p>
					<p class='tracking-[0.2em]'>01010111 01001000 01000101 01000001 01010100</p>
				</div>
			</footer>
		</div>

		<script is:inline define:vars={{ locale }}>
			localStorage.setItem('macrocalc-locale', locale)
		</script>
	</body>
</html>
