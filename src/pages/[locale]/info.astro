---
import InfoModules from '@components/InfoModules.astro'
import SEO from '@components/SEO.astro'
import '@styles/global.css'

export function getStaticPaths() {
	return [
		{ params: { locale: 'en' } },
		{ params: { locale: 'es' } },
		{ params: { locale: 'fr' } },
		{ params: { locale: 'zh' } },
		{ params: { locale: 'hi' } },
	]
}

const { locale } = Astro.params as { locale: 'en' | 'es' | 'fr' | 'zh' | 'hi' }

const BASE = '/macronutrients'
---

<html lang={locale}>
	<head>
		<meta charset='utf-8' />
		<link rel='icon' type='image/svg+xml' href={`${BASE}/favicon.svg`} />
		<meta name='viewport' content='width=device-width' />
		<meta name='generator' content={Astro.generator} />
		<link rel='preconnect' href='https://fonts.googleapis.com' />
		<link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
		<link href='https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,700;0,800;1,800&display=swap' rel='stylesheet' />

		<SEO locale={locale} page='info' />
	</head>
	<body class='min-h-screen bg-[#0A0A0A] text-gray-100'>
		<div class='mx-auto w-full max-w-xl p-4 md:p-8'>
			<InfoModules locale={locale} />
		</div>

		<script is:inline define:vars={{ locale }}>
			localStorage.setItem('macrocalc-locale', locale)
		</script>
	</body>
</html>
