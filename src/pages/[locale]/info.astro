---
import { AppHeader } from '@components/AppHeader'
import InfoModules from '@components/InfoModules.astro'
import BaseLayout from '../../layouts/BaseLayout.astro'
import '@styles/global.css'

export function getStaticPaths() {
	return [
		{ params: { locale: 'en' } },
		{ params: { locale: 'es' } },
		{ params: { locale: 'fr' } },
		{ params: { locale: 'zh' } },
		{ params: { locale: 'hi' } },
	]
}

const { locale } = Astro.params as { locale: 'en' | 'es' | 'fr' | 'zh' | 'hi' }
---

<BaseLayout locale={locale} page='info' containerClass='p-4 md:p-8'>
	<AppHeader client:only='react' />
	<InfoModules locale={locale} />
</BaseLayout>
