---
import { AdditionalSettings } from '@components/AdditionalSettings'
import ChartMacros from '@components/ChartMacros.astro'
import { Dashboard } from '@components/Dashboard'
import { ExerciseMultiplier } from '@components/ExerciseMultiplier'
import { GoalSelector } from '@components/GoalSelector'
import '@styles/global.css'
import '@styles/selects.css'
---

<html lang='en'>
	<head>
		<meta charset='utf-8' />
		<link rel='icon' type='image/svg+xml' href='/macronutrients/favicon.svg' />
		<meta name='viewport' content='width=device-width' />
		<meta name='generator' content={Astro.generator} />
		<link rel='preconnect' href='https://fonts.googleapis.com' />
		<link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
		<link
			href='https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,700;0,800;1,800&display=swap'
			rel='stylesheet'
		/>

		<title>MacroCalc</title>
		<meta name='title' content='Macronutrients' />
		<meta name='description' content='MacroCalc is a website to calculate the macronutrients that you need' />
		<meta
			name='keywords'
			content='macronutrients,macronutrients calculation,proteins,proteins calculation,carbs carbs calculation,fats,fats calculation'
		/>
		<meta http-equiv='Content-Type' content='text/html; charset=utf-8' />
		<meta name='language' content='English' />
		<meta name='author' content='Alberto García Sola' />
	</head>
	<body class='bg-[#0A0A0A] text-gray-100 min-h-screen'>
		<div class='w-full max-w-md mx-auto p-4 md:p-8'>
			<header class='border-b-8 border-[#4A4A4A] pb-4 mb-8'>
				<h1 class='text-4xl font-extrabold leading-none italic'>CAL_CALC_V1.0</h1>
				<div class='flex justify-between items-center mt-1'>
					<p class='text-[10px] opacity-60'>SYSTEM STATUS: OPTIMAL // BRUTALIST NUTRITION ENGINE</p>
					<div class='flex gap-1'>
						<div class='w-2 h-2 bg-emerald-500 animate-pulse'></div>
						<div class='w-2 h-2 bg-[#4A4A4A]'></div>
						<div class='w-2 h-2 bg-[#4A4A4A]'></div>
					</div>
				</div>
			</header>

			<div class='flex flex-col gap-8'>
				<div>
					<Dashboard client:load />
				</div>
				<div>
					<ExerciseMultiplier client:load />
				</div>
				<div>
					<GoalSelector client:load />
				</div>
				<div>
					<ChartMacros />
				</div>
				<AdditionalSettings client:load />
			</div>

			<footer class='text-[9px] text-center opacity-40 py-12 border-t-2 border-dashed border-[#4A4A4A] space-y-2 mt-8'>
				<p>DATA_RECONSTRUCTED // UNIT_SYSTEM: METRIC // SOURCE: MIFFLIN-ST_JEOR_REVISED</p>
				<p class='tracking-[0.2em]'>01010111 01001000 01000101 01000001 01010100</p>
			</footer>
		</div>
	</body>
</html>
