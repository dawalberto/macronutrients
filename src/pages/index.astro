---
import { AdditionalSettings } from '@components/AdditionalSettings'
import { AppHeader } from '@components/AppHeader'
import ChartMacros from '@components/ChartMacros.astro'
import { Dashboard } from '@components/Dashboard'
import { ExerciseMultiplier } from '@components/ExerciseMultiplier'
import { InterpretResults } from '@components/InterpretResults'
import { GoalSelector } from '@components/GoalSelector'
import { LanguageSelector } from '@components/LanguageSelector'
import '@styles/global.css'
---

<html lang='en'>
	<head>
		<meta charset='utf-8' />
		<link rel='icon' type='image/svg+xml' href='/macronutrients/favicon.svg' />
		<meta name='viewport' content='width=device-width' />
		<meta name='generator' content={Astro.generator} />
		<link rel='preconnect' href='https://fonts.googleapis.com' />
		<link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
		<link href='https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,700;0,800;1,800&display=swap' rel='stylesheet' />

		<title>MacroCalc</title>
		<meta name='title' content='Macronutrients' />
		<meta name='description' content='MacroCalc is a website to calculate the macronutrients that you need' />
		<meta
			name='keywords'
			content='macronutrients,macronutrients calculation,proteins,proteins calculation,carbs carbs calculation,fats,fats calculation'
		/>
		<meta http-equiv='Content-Type' content='text/html; charset=utf-8' />
		<meta name='language' content='English' />
		<meta name='author' content='Alberto García Sola' />
	</head>
	<body class='min-h-screen bg-[#0A0A0A] text-gray-100'>
		<div class='mx-auto w-full max-w-xl p-4 md:p-8'>
			<AppHeader client:load />

			<div class='flex flex-col gap-8'>
				<Dashboard client:load />
				<ExerciseMultiplier client:load />
				<GoalSelector client:load />
				<ChartMacros />
				<InterpretResults client:load />
				<AdditionalSettings client:load />
			</div>

			<footer class='mt-8 border-t-2 border-dashed border-[#4A4A4A] py-12'>
				<nav class='mb-6 flex justify-center'>
					<a id='footer-info-link' href='/macronutrients/info' class='text-[clamp(10px,1.1vw,12px)] font-bold opacity-40 transition-opacity hover:opacity-100'>
						INFO // FORMULAS & DEFINITIONS →
					</a>
				</nav>
				<div class='mb-6 flex justify-center'>
					<LanguageSelector client:load />
				</div>
				<div class='space-y-2 text-center text-[clamp(8px,1vw,10px)] opacity-40'>
					<p>DATA_RECONSTRUCTED // UNIT_SYSTEM: METRIC // SOURCE: MIFFLIN-ST_JEOR_REVISED</p>
					<p class='tracking-[0.2em]'>01010111 01001000 01000101 01000001 01010100</p>
				</div>
			</footer>
		</div>

		<script>
			import { $locale } from '@store/locale'
			import { getTranslations } from '@i18n/index'

			function updateStaticText() {
				const t = getTranslations()
				const footerLink = document.getElementById('footer-info-link')
				if (footerLink) footerLink.textContent = t.footer_info_link
				document.documentElement.lang = $locale.get()
			}

			$locale.subscribe(updateStaticText)
		</script>
	</body>
</html>
