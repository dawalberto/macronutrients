---
// Root landing — detects preferred locale and redirects to the correct prefixed URL.
// Also emits hreflang for the 5 supported locales so search engines can discover them.
const BASE = ''
const SUPPORTED = ['en', 'es', 'fr', 'zh', 'hi'] as const
const SITE = 'https://macrocalc.fit'
---

<html lang='en'>
	<head>
		<meta charset='utf-8' />
		<meta name='viewport' content='width=device-width' />
		<title>MacroCalc</title>
		<meta name='robots' content='noindex, follow' />

		<!-- hreflang for crawler discoverability -->
		{SUPPORTED.map((loc) => <link rel='alternate' hreflang={loc} href={`${SITE}${BASE}/${loc}/`} />)}
		<link rel='alternate' hreflang='x-default' href={`${SITE}${BASE}/en/`} />

		<!-- Immediate meta-refresh fallback to English (overridden by JS below) -->
		<meta http-equiv='refresh' content={`0; url=${BASE}/en/`} />
	</head>
	<body>
		<script is:inline define:vars={{ BASE, SUPPORTED }}>
			const nav = navigator.language.split('-')[0]
			const stored = localStorage.getItem('macrocalc-locale')
			const locale = SUPPORTED.includes(stored) ? stored : SUPPORTED.includes(nav) ? nav : 'en'
			window.location.replace(`${BASE}/${locale}/`)
		</script>
	</body>
</html>
